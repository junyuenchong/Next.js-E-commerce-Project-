{
  "name": "e-commerce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "tsx scripts/clean-next.ts",
    "dev": "next dev",
    "dev:clean": "tsx scripts/clean-next.ts && next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build --no-lint",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "db:seed": "tsx scripts/seed.ts",
    "db:check": "tsx scripts/check.ts",
    "worker:payment": "tsx scripts/workers/payment-worker.ts",
    "worker:email": "tsx scripts/workers/email-worker.ts",
    "worker:analytics": "tsx scripts/workers/analytics-worker.ts"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@prisma/client": "^6.11.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@tanstack/react-query": "^5.96.2",
    "@types/bcryptjs": "^2.4.6",
    "amqplib": "^0.10.9",
    "autoprefixer": "^10.4.21",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "next": "15.5.14",
    "next-auth": "^4.24.11",
    "node": "^20.19.4",
    "nodemailer": "^7.0.13",
    "postcss": "^8.5.6",
    "react": "^19.1.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "redis": "^4.7.1",
    "redux-persist": "^6.0.0",
    "sharp": "^0.34.2",
    "slugify": "^1.6.6",
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mkcert": "^3.2.0",
    "prettier": "^3.8.1",
    "prisma": "^6.11.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": [
      "prettier --write"
    ],
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
