# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME"
# Neon pooled hostnames contain "pooler" — the app adds ?pgbouncer=true automatically so Prisma
# avoids prepared-statement errors. For `prisma migrate`, prefer Neon’s direct (non-pooler) URL.

# NextAuth
NEXTAUTH_SECRET=
# Site origin (no path). OAuth: register callback URLs in Google/Facebook (use the module path;
# `/api/auth/*` is rewritten to the same handler for legacy console entries):
#   http://localhost:3000/modules/user/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google  → rewrite → same as above
NEXTAUTH_URL=http://localhost:3000

# Optional — local/dev only: seed a password-based SUPER_ADMIN (same hashing as Sign up / Sign in).
# Run: npm run db:seed — then sign in at /modules/user/auth/sign-in (Local / email + password).
# Replace with strong secrets before any shared or production deploy.
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=admin

# Public site URL (password reset links, metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PayPal (sandbox REST host is always api-m.sandbox.paypal.com unless going live)
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_KEY=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CURRENCY=MYR
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CURRENCY=MYR

# Twilio SMS (optional — used for checkout SMS receipt if user enters a phone)
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=

# Gmail / SMTP (optional — receipt email when user is signed in)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# RabbitMQ (optional) — after PayPal capture: order.email + order.inventory queues (no exchange).
# Without RABBITMQ_URL, receipt email + stock decrement run synchronously in the capture route.
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# RABBITMQ_QUEUE_ORDER_EMAIL=order.email
# RABBITMQ_QUEUE_ORDER_INVENTORY=order.inventory

