# =========================
# Database
# =========================
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DBNAME"
# Optional direct/non-pooler URL (useful for migrate on some managed providers)
DATABASE_URL_UNPOOLED=

# =========================
# Auth / Site
# =========================
NEXTAUTH_SECRET=
# Local dev
NEXTAUTH_URL=http://localhost:3000
# Public site origin for links/metadata (set production domain on deploy)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# Callback examples:
# - http://localhost:3000/api/auth/callback/google
# - http://localhost:3000/api/auth/callback/facebook
# - https://<your-domain>/api/auth/callback/google
# - https://<your-domain>/api/auth/callback/facebook

# =========================
# Admin seed (optional, local/dev)
# =========================
ADMIN_EMAILS=admin@gmail.com
ADMIN_SEED_EMAIL=admin@gmail.com
ADMIN_SEED_PASSWORD=change_me_strong_password

# =========================
# Payments (PayPal)
# =========================
PAYPAL_CLIENT_ID=
PAYPAL_SECRET_KEY=
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# Required for webhook signature verification
PAYPAL_WEBHOOK_ID=
PAYPAL_CURRENCY=MYR
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CURRENCY=MYR
# Set to 1 to make webhook the final source of truth for payment/order finalization.
PAYMENT_WEBHOOK_TRUTH=0
# Inventory deduction policy:
# - FULFILLED: deduct stock when order enters fulfilled (default)
# - PAID: Shopee-like behavior, deduct stock immediately after payment is persisted
STOCK_DEDUCT_MODE=FULFILLED

# =========================
# Notifications
# =========================
# Twilio SMS (optional)
TWILIO_SID=
TWILIO_AUTH=
TWILIO_FROM=

# SMTP / Gmail (optional)
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# =========================
# Media (optional)
# =========================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =========================
# Messaging workers (optional)
# =========================
# Without RABBITMQ_URL, email/inventory flows may run inline.
# RABBITMQ_URL=amqp://guest:guest@localhost:5672
# RABBITMQ_QUEUE_ORDER_EMAIL=order.email
# RABBITMQ_QUEUE_ORDER_INVENTORY=order.inventory

# =========================
# Cron / Jobs (optional)
# =========================
# Protect internal cron routes like /features/admin/api/payments/expire
CRON_SECRET=

