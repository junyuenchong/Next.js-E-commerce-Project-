// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// Identity & Authentication
// =========================
enum UserRole {
  USER
  STAFF
  ADMIN
  SUPER_ADMIN
}

model User {
  id Int @id @default(autoincrement())

  // Identity
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Access control
  role                  UserRole             @default(USER)
  isActive              Boolean              @default(true)
  /// RBAC profile (`AdminRoleDefinition.id`) for `ADMIN` / `STAFF` only; must be null for `USER`. `SUPER_ADMIN` uses the built-in profile in app code (this field ignored when resolving permissions).
  adminPermissionRoleId Int?
  adminPermissionRole   AdminRoleDefinition? @relation(fields: [adminPermissionRoleId], references: [id], onDelete: SetNull)

  // Relations
  session              Session[]
  cart                 Cart?
  reviews              ProductReview[]
  orders               Order[]
  payments             Payment[]
  wishlist             WishlistItem[]
  passwordResets       PasswordResetToken[]
  addresses            UserAddress[]
  couponAssignments    UserCouponAssignment[]
  supportConversations SupportConversation[]
  supportMessages      SupportMessage[]       @relation("SupportMessageUser")
  supportAdminMessages SupportMessage[]       @relation("SupportMessageAdmin")
  accounts             Account[]
  adminActionLogs      AdminActionLog[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminPermissionRoleId])
}

// ===============
// Support / Inbox
// ===============
enum SupportConversationStatus {
  OPEN
  CLOSED
}

model SupportConversation {
  id Int @id @default(autoincrement())

  // Ownership / status
  userId Int
  user   User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status SupportConversationStatus @default(OPEN)

  // Conversation snapshot
  subject       String?  @db.VarChar(200)
  lastMessageAt DateTime @default(now())

  // Relations / timestamps
  messages  SupportMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, lastMessageAt])
  @@index([status, lastMessageAt])
  @@index([lastMessageAt])
}

enum SupportMessageSenderType {
  USER
  ADMIN
}

model SupportMessage {
  id Int @id @default(autoincrement())

  // Conversation identity
  conversationId Int
  conversation   SupportConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderType     SupportMessageSenderType

  // Sender snapshot
  userSenderId  Int?
  userSender    User? @relation("SupportMessageUser", fields: [userSenderId], references: [id], onDelete: SetNull)
  adminSenderId Int?
  adminSender   User? @relation("SupportMessageAdmin", fields: [adminSenderId], references: [id], onDelete: SetNull)

  // Message body / timestamp
  body      String   @db.VarChar(4000)
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@index([userSenderId])
  @@index([adminSenderId])
}

/// Append-only audit of sensitive admin actions (refund, ban, catalog removals).
model AdminActionLog {
  id Int @id @default(autoincrement())

  // Actor / event identity
  actorUserId Int?
  actor       User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String

  // Target snapshot
  targetType String?
  targetId   String?
  metadata   Json?

  // Timestamp
  createdAt DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
  @@index([action, id])
}

// =======================
// Admin Roles & Auditing
// =======================
/// Named permission profiles (built-in + custom). `slug` is the stable code key.
model AdminRoleDefinition {
  id Int @id @default(autoincrement())

  // Identity
  slug String @unique
  name String

  // Profile behavior
  isSystem  Boolean @default(false)
  /// Soft-remove custom profiles; inactive profiles are hidden from assignment and ignored for permission resolution.
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  // Relations
  permissions AdminRolePermission[]
  users       User[]

  @@index([isActive])
}

/// Canonical admin actions (stable `key` for code checks; `id` for APIs and role matrix).
model AdminPermission {
  id Int @id @default(autoincrement())

  // Identity
  key   String @unique
  label String

  // Display order / relations
  sortOrder  Int                   @default(0)
  roleGrants AdminRolePermission[]
}

model AdminRolePermission {
  id Int @id @default(autoincrement())

  // Relation keys
  roleId       Int
  permissionId Int

  // Relations
  role       AdminRoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission AdminPermission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ==================
// User Profile Data
// ==================
model UserAddress {
  id Int @id @default(autoincrement())

  // Ownership
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Address snapshot
  label    String?
  line1    String
  city     String
  postcode String
  country  String  @default("Malaysia")

  // State / timestamps
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isDefault])
  @@index([userId, isActive])
}

model PasswordResetToken {
  id Int @id @default(autoincrement())

  // Ownership
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token lifecycle
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id String @id @default(cuid())

  // Session identity
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  // Relation
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ===================
// Catalog & Discovery
// ===================
model Category {
  id Int @id @default(autoincrement())

  // Identity
  name String @unique
  slug String @unique

  // Visibility / relations
  isActive Boolean   @default(true)
  products Product[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Product {
  id Int @id @default(autoincrement())

  // Core identity
  title       String
  slug        String  @unique
  description String?

  // Pricing / availability
  /// Optional list / MSRP price; when greater than `price`, storefront shows a discount.
  compareAtPrice Decimal? @db.Decimal(12, 2)
  price          Decimal  @db.Decimal(12, 2)
  imageUrl       String?
  stock          Int      @default(0)
  isActive       Boolean  @default(true)

  // Category relation
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // Relations / timestamps
  cartItems  CartLineItem[]
  reviews    ProductReview[]
  orderLines OrderLineItem[]
  wishlists  WishlistItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([categoryId])
  @@index([isActive, createdAt])
  @@index([categoryId, isActive, createdAt])
  @@index([categoryId, id])
  @@index([categoryId, isActive, id])
}

model WishlistItem {
  id Int @id @default(autoincrement())

  // Ownership
  userId    Int
  productId Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // State / timestamp
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([userId, isActive])
}

model ProductReview {
  id Int @id @default(autoincrement())

  // Ownership
  productId Int
  userId    Int
  rating    Int
  comment   String

  // Moderation / status
  adminReply String?
  isActive   Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([productId, isActive, createdAt])
}

model CartLineItem {
  id String @id @default(cuid())

  // Ownership
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int

  // Snapshot fields
  title String?
  price Decimal? @db.Decimal(12, 2)
  image String?

  // Parent relation
  cartId String
  cart   Cart   @relation(references: [id], fields: [cartId], onDelete: Cascade)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// ====================
// Cart & Auth Accounts
// ====================
model Cart {
  id String @id @default(cuid())

  // Ownership
  userId Int?  @unique
  user   User? @relation(references: [id], fields: [userId], onDelete: Cascade)

  // Cart state
  items       CartLineItem[]
  expiresAt   DateTime
  guestCartId String?        @unique

  @@index([expiresAt])
}

model Account {
  id Int @id @default(autoincrement())

  // Owner / provider identity
  userId            Int
  type              String
  provider          String
  providerAccountId String

  // OAuth/session token fields
  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ===================
// Orders & Promotions
// ===================
enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
  fulfilled
}

// =====================
// Payments & Webhooks
// =====================
enum PaymentProvider {
  PAYPAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum CouponRedemptionScope {
  PUBLIC
  ASSIGNED_USERS
}

model Coupon {
  id Int @id @default(autoincrement())

  // Identity
  code        String  @unique
  description String?

  // Discount rules
  discountType     CouponDiscountType
  /// Percent (e.g. 10 = 10%) or fixed amount in order currency.
  value            Decimal            @db.Decimal(12, 2)
  minOrderSubtotal Decimal?           @db.Decimal(12, 2)
  maxDiscount      Decimal?           @db.Decimal(12, 2)

  // Validity / usage controls
  startsAt   DateTime?
  endsAt     DateTime?
  usageLimit Int?
  usedCount  Int       @default(0)
  isActive   Boolean   @default(true)

  // Storefront exposure
  /// Who can redeem this code at checkout.
  redemptionScope  CouponRedemptionScope @default(PUBLIC)
  /// Shown on cart/checkout “vouchers” strip (Amazon-style tap-to-apply).
  showOnStorefront Boolean               @default(false)
  voucherHeadline  String?               @db.VarChar(160)

  // Relations / timestamps
  orders      Order[]
  assignments UserCouponAssignment[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@index([isActive, code])
  @@index([showOnStorefront, isActive])
}

model UserCouponAssignment {
  id Int @id @default(autoincrement())

  // Ownership
  userId   Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  couponId Int
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  // Assignment lifecycle
  assignedAt DateTime  @default(now())
  emailedAt  DateTime?
  usedAt     DateTime?

  @@unique([userId, couponId])
  @@index([couponId, assignedAt])
  @@index([userId, assignedAt])
}

model Order {
  id Int @id @default(autoincrement())

  // Ownership / identity snapshot
  userId        Int?
  user          User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  emailSnapshot String?

  // Financial status
  status             OrderStatus @default(pending)
  currency           String
  total              Decimal     @db.Decimal(12, 2)
  paypalOrderId      String      @unique
  paypalCaptureId    String?
  couponId           Int?
  coupon             Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCodeSnapshot String?
  discountAmount     Decimal     @default(0) @db.Decimal(12, 2)

  // Shipping snapshot
  shippingLine1    String?
  shippingCity     String?
  shippingPostcode String?
  shippingCountry  String?
  shippingMethod   String?
  shippingCarrier  String?
  trackingNumber   String?
  trackingUrl      String?
  shippedAt        DateTime?

  // Relations / timestamps
  items     OrderLineItem[]
  invoice   Invoice?
  payments  Payment[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([userId, id])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([couponId])
}

/// Canonical payment record created before calling a gateway.
/// Webhook events are the source of truth for final status transitions.
model Payment {
  id Int @id @default(autoincrement())

  // Ownership context (order is linked after persistence)
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Optional link once an order is persisted
  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // Gateway identity
  provider          PaymentProvider
  providerOrderId   String?         @unique
  providerCaptureId String?

  // Backend-calculated amount snapshot (never trust frontend)
  currency String
  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  // Safety controls
  idempotencyKey String
  status         PaymentStatus @default(PENDING)
  expiresAt      DateTime
  version        Int           @default(0)

  // Audit snapshots
  gatewayResponse Json?

  // Relations / timestamps
  webhookEvents PaymentWebhookEvent[]
  statusHistory PaymentStatusHistory[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([provider, idempotencyKey])
  @@index([userId, createdAt])
  @@index([orderId])
  @@index([provider, status, expiresAt])
}

/// Deduplicated webhook inbox (unique by provider + eventId).
model PaymentWebhookEvent {
  id Int @id @default(autoincrement())

  provider PaymentProvider
  eventId  String

  paymentId Int?
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  signatureVerified Boolean @default(false)
  payloadRaw        Json

  receivedAt   DateTime  @default(now())
  handledAt    DateTime?
  handleResult String?

  @@unique([provider, eventId])
  @@index([paymentId, receivedAt])
  @@index([provider, receivedAt])
}

/// Append-only status transitions for auditing and support.
model PaymentStatusHistory {
  id Int @id @default(autoincrement())

  paymentId Int
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  fromStatus PaymentStatus?
  toStatus   PaymentStatus
  reason     String?
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([paymentId, createdAt])
  @@index([toStatus, createdAt])
}

model Invoice {
  id Int @id @default(autoincrement())

  // One invoice per order
  orderId Int   @unique
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Invoice identity
  invoiceNumber String   @unique
  issuedAt      DateTime @default(now())
  status        String   @default("issued")

  // Billed snapshot
  billedEmail String?
  currency    String
  subtotal    Decimal @db.Decimal(12, 2)
  discount    Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  couponCode  String?
  lineItems   Json?

  @@index([issuedAt])
}

model OrderLineItem {
  id Int @id @default(autoincrement())

  // Parent relations
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  // Snapshot fields
  title     String
  unitPrice Decimal @db.Decimal(12, 2)
  quantity  Int
  imageUrl  String?

  @@index([orderId])
  @@index([productId])
}
